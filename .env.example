# --- Core ---
# Postgres ayrı bir sunucuda çalışıyor — docker-compose bu servisi
# barındırmıyor, backend sadece bu URL üzerinden ağ üzerinden bağlanır.
DATABASE_URL=postgresql+psycopg://gitdeep:gitdeep_password@db.example.internal:5432/gitdeep
SECRET_KEY=change-me-generate-a-long-random-string
REFRESH_SECRET_KEY=change-me-too-different-random-string
EMAIL_LINK_SECRET=change-me-hmac-sha256-signing-key
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
COOKIE_SECURE=false

# --- SMTP (dev: Mailpit; prod'da gerçek sağlayıcı — SES/Postmark/Resend vb.) ---
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=none

# --- Amaca göre gönderici adresleri ---
# Her e-posta türü kendi kutusundan gider; örn. şifre sıfırlama support@'tan,
# bülten onayı newsletter@'tan gider. Yeni bir e-posta türü eklerken buraya
# yeni bir EMAIL_FROM_* değişkeni eklemek yeterli.
EMAIL_FROM_SUPPORT=support@gitdeep.dev
EMAIL_FROM_NEWSLETTER=newsletter@gitdeep.dev
EMAIL_FROM_DEFAULT=no-reply@gitdeep.dev

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api
